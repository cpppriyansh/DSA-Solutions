// Online C++ compiler to run C++ program online
#include <iostream>
#include <climits>
#include <vector>
using namespace std;

int main() {
    vector<int> nums = {1, 3, -1, -3, 5, 3, 6, 7};
    int k = 3;
    
    vector<int> v;
    
    for(int i  = 0; i<=nums.size()-k; i++){
        int maxo = INT_MIN;
        for(int j = i; j<i+k; j++){
            int a = nums[j];
            maxo = max(maxo, a);
        }
        v.push_back(maxo);
    }
    
    for(int i = 0; i<v.size(); i++){
        cout<<v[i]<<" ";
    }

    return 0;
}
